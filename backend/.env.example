# =============================================================================
# ORCHESTRATION MODEL
# Used by: Preference, Research, Route, Budget, Critic, Revision agents.
# Must support OpenAI-style tool calling (function calling).
#
# DEFAULT: OpenAI API. Set ORCH_API_KEY to your key.
# Other providers: anything OpenAI-compatible with tool-calling support
# (OpenRouter, Together, Anthropic via SDK shim, vLLM with --enable-auto-tool-choice).
# =============================================================================

ORCH_BASE_URL=https://api.openai.com/v1
ORCH_API_KEY=sk-replace-me
ORCH_MODEL=gpt-4o

# =============================================================================
# TAVILY WEB SEARCH
# Used by Research (find real places) and Budget (real prices).
# Get a key at https://tavily.com (free tier: 1000 searches/month).
# =============================================================================

TAVILY_API_KEY=tvly-replace-me

# =============================================================================
# FUTURE: SELF-HOSTED ORCHESTRATION
# When you provision a GPU host with enough disk, launch:
#
#   CUDA_VISIBLE_DEVICES=0 vllm serve QuantTrio/Qwen3.6-35B-A3B-AWQ \
#     --port 8000 --gpu-memory-utilization 0.85 --max-model-len 16384 \
#     --enable-auto-tool-choice --tool-call-parser hermes
#
# Then replace the three ORCH_* lines above with:
#
# ORCH_BASE_URL=http://<gpu-host>:8000/v1
# ORCH_API_KEY=dummy
# ORCH_MODEL=QuantTrio/Qwen3.6-35B-A3B-AWQ
# =============================================================================


# =============================================================================
# ITINERARY MODEL (fine-tuned, always self-hosted)
# Used by: Itinerary agent only.
#
# On the GPU host (vLLM path):
#   CUDA_VISIBLE_DEVICES=1 vllm serve Qwen/Qwen2.5-7B-Instruct \
#     --port 8001 --gpu-memory-utilization 0.85 --max-model-len 4096 \
#     --enable-lora --max-lora-rank 16 \
#     --lora-modules tripwise=/path/to/tripwise-itinerary-lora
#
# OR (transformers fallback if vLLM doesn't cooperate with the host driver):
#   CUDA_VISIBLE_DEVICES=1 HF_HOME=/workspace/.hf_home \
#     python serve_lora.py --port 8001
# =============================================================================

ITIN_BASE_URL=http://localhost:8001/v1
ITIN_API_KEY=dummy
ITIN_MODEL=tripwise

# DEV FALLBACK: if the GPU host isn't ready, point ITIN_* at the same OpenAI-
# compatible endpoint as ORCH_* and the pipeline runs end-to-end. The Itinerary
# agent uses GPT instead of the LoRA — schema conformance is weaker but the
# rest of the system works.
